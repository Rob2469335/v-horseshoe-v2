# .env.example — copy to .env and fill in your keys
# V2 server
VH2_PORT=8100

# Swarm (V1) — leave as-is unless you moved it
SWARM_BASE_URL=http://localhost:11436

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Model overrides (optional — defaults are set in settings.py)
# VH2_TRIAGE_MODEL=qwen2.5:3b-instruct
# VH2_FAST_MODEL=qwen2.5:7b-instruct
# VH2_CODER_MODEL=qwen2.5-coder:7b-16k
# VH2_HEAVY_MODEL=qwen3:14b

# Qdrant (local mode by default — no server needed)
QDRANT_LOCAL=true
# Set to false and configure below if running Qdrant as a server
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# MCP servers
MCP_PLAYWRIGHT_URL=http://localhost:8931/mcp
# MCP_CONTEXT7_URL=http://localhost:7777/mcp

# Search providers — add keys for the ones you have
SEARXNG_URL=http://localhost:8080
BRAVE_API_KEY=
TINYFISH_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_KEY=

# Feature flags
VH2_QDRANT_ENABLED=true
VH2_RERANKER_ENABLED=true
VH2_MCP_PLAYWRIGHT=true
VH2_MCP_FILESYSTEM=true
VH2_MCP_CONTEXT7=false
VH2_BP_HOT_RELOAD=true
VH2_AUTONOMOUS_MODE=false
VH2_SSE_DEBUG=false
